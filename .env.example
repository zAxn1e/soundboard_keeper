# Discord bot token from Developer Portal
BOT_TOKEN=TOKEN_HERE

# Optional: auto-connect when bot starts (set to 0 to disable)
DEFAULT_GUILD_ID=0
DEFAULT_CHANNEL_ID=0

# SYNC
SYNC_GUILD_IDS=797653868635750461

# Voice self-state on join
SELF_DEAF=false
SELF_MUTE=true

# Reconnect behavior
WATCHDOG_INTERVAL_SECONDS=5
CONNECT_RETRY_LIMIT=50
MIN_RECONNECT_INTERVAL_SECONDS=3
VOICE_RECOVERY_GRACE_SECONDS=35
COMMAND_SYNC_TIMEOUT_SECONDS=30

# Slash command dedup (remove old global commands when using guild sync)
PURGE_GLOBAL_COMMANDS_ON_GUILD_SYNC=true

# Soundboard behavior
SOUNDBOARD_DISCONNECT_AFTER_PLAY=true
SOUNDBOARD_MAX_FILE_SIZE_MB=10
SOUNDBOARD_ALLOWED_EXTENSIONS=.mp3,.wav,.ogg,.m4a
SOUNDBOARD_STORAGE_DIR=sounds
SOUNDBOARD_DB_PATH=soundboard.sqlite3
